## Copy this file to .env and fill in your values

NODE_ENV=development
PORT=5000

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/logiclords
# For MongoDB Atlas:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/logiclords?retryWrites=true&w=majority

# JWT — CHANGE THIS in production!
JWT_SECRET=logiclords_super_secret_change_me_in_production
JWT_EXPIRES_IN=7d

# Frontend origin for CORS
CLIENT_URL=http://localhost:3000

# Optional: Cloudinary for avatar hosting (leave blank to use local disk)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
